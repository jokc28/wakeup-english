# Copy to .env.local and fill with real values.
# Do not commit .env.local.

REVENUECAT_IOS_API_KEY=appl_xxx
REVENUECAT_ANDROID_API_KEY=goog_xxx

# Optional, for future App Store Connect automation.
APP_STORE_CONNECT_ISSUER_ID=
APP_STORE_CONNECT_KEY_ID=
APP_STORE_CONNECT_PRIVATE_KEY_PATH=

# Optional, for future Play Console automation.
GOOGLE_PLAY_PACKAGE_NAME=com.wakeup.english.wakeup_english
GOOGLE_APPLICATION_CREDENTIALS=
